{
  "uid": "llm-queue-kafka",
  "title": "LLM Queue & Kafka",
  "tags": ["manuscriptum", "llm", "kafka"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Pending",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Pending\" FROM llm_prompt_queue WHERE status = 'pending'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Total Processing",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Processing\" FROM llm_prompt_queue WHERE status = 'processing'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "yellow", "value": null }] } } }
    },
    {
      "id": 3,
      "title": "Total Completed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Completed\" FROM llm_prompt_queue WHERE status = 'completed'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 4,
      "title": "Total Failed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Failed\" FROM llm_prompt_queue WHERE status = 'failed'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 1 },
        { "color": "red", "value": 10 }
      ] } } }
    },
    {
      "id": 5,
      "title": "Total Applied",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Applied\" FROM llm_prompt_queue WHERE status = 'applied'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 6,
      "title": "Queue Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Total\" FROM llm_prompt_queue",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 7,
      "title": "Pending by Phase",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT phase_name AS \"Phase\", COUNT(*) AS \"Pending\" FROM llm_prompt_queue WHERE status = 'pending' GROUP BY phase_name ORDER BY 2 DESC",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "blue", "value": null },
        { "color": "yellow", "value": 100 },
        { "color": "red", "value": 500 }
      ] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "Queue Throughput Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT $__timeGroup(processed_at, '5m', 0) AS time, COUNT(*) FILTER (WHERE status = 'completed') AS \"Completed\", COUNT(*) FILTER (WHERE status = 'failed') AS \"Failed\", COUNT(*) FILTER (WHERE status = 'applied') AS \"Applied\" FROM llm_prompt_queue WHERE $__timeFilter(processed_at) AND processed_at IS NOT NULL GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Applied" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple" } }] }
        ]
      }
    },
    {
      "id": 9,
      "title": "Phase Status Overview",
      "type": "table",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT phase_name AS \"Phase\", COUNT(*) FILTER (WHERE status = 'pending') AS \"Pending\", COUNT(*) FILTER (WHERE status = 'processing') AS \"Processing\", COUNT(*) FILTER (WHERE status = 'completed') AS \"Completed\", COUNT(*) FILTER (WHERE status = 'failed') AS \"Failed\", COUNT(*) FILTER (WHERE status = 'applied') AS \"Applied\", COUNT(*) AS \"Total\", ROUND(COUNT(*) FILTER (WHERE status IN ('completed','applied')) * 100.0 / NULLIF(COUNT(*), 0), 1) AS \"Success %\" FROM llm_prompt_queue GROUP BY phase_name ORDER BY \"Pending\" DESC, phase_name",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success %" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
            { "id": "min", "value": 0 },
            { "id": "max", "value": 100 },
            { "id": "unit", "value": "percent" },
            { "id": "thresholds", "value": { "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ] } }
          ] }
        ]
      }
    },
    {
      "id": 10,
      "title": "Enqueue Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT $__timeGroup(created_at, '10m', 0) AS time, COUNT(*) AS \"Enqueued\" FROM llm_prompt_queue WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 }, "color": { "fixedColor": "blue" } } }
    },
    {
      "id": 11,
      "title": "Avg Processing Time by Phase",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT phase_name AS \"Phase\", COUNT(*) AS \"Items\", ROUND(AVG(EXTRACT(EPOCH FROM (processed_at - created_at)))) AS \"Avg Duration (s)\", ROUND(MAX(EXTRACT(EPOCH FROM (processed_at - created_at)))) AS \"Max Duration (s)\" FROM llm_prompt_queue WHERE processed_at IS NOT NULL GROUP BY phase_name ORDER BY 3 DESC",
        "format": "table"
      }]
    },
    {
      "id": 12,
      "title": "Usage by Tier",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT tier AS \"Tier\", COUNT(*) AS \"Count\" FROM llm_prompt_queue GROUP BY tier ORDER BY 2 DESC",
        "format": "table"
      }]
    },
    {
      "id": 13,
      "title": "Recent Failed Items",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT phase_name AS \"Phase\", label AS \"Label\", LEFT(error_message, 100) AS \"Error\", created_at AS \"Created\" FROM llm_prompt_queue WHERE status = 'failed' ORDER BY created_at DESC LIMIT 20",
        "format": "table"
      }]
    },
    {
      "id": 14,
      "title": "Queue & Kafka Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{container=~\".*app.*\"} |~ \"(LLM_PROCESSOR|KAFKA_PRODUCER|LLM_QUEUE)\"",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ],
  "schemaVersion": 39
}
