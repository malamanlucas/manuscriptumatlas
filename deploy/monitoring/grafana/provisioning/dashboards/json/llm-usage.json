{
  "uid": "llm-usage",
  "title": "LLM Usage & Cost",
  "tags": ["manuscriptum", "llm"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Total\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Success Rate (24h)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE success = true) * 100.0 / NULLIF(COUNT(*), 0), 1) AS \"Rate\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 98 }
          ] }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Cost (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COALESCE(ROUND(SUM(estimated_cost_usd)::numeric, 4), 0) AS \"Cost USD\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 5 },
        { "color": "red", "value": 20 }
      ] } } }
    },
    {
      "id": 4,
      "title": "Total Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COALESCE(SUM(total_tokens), 0) AS \"Tokens\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 5,
      "title": "Avg Latency (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND(AVG(latency_ms)) AS \"Avg ms\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours' AND success = true",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 3000 },
        { "color": "red", "value": 10000 }
      ] } } }
    },
    {
      "id": 6,
      "title": "Failed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Failed\" FROM llm_usage_logs WHERE created_at >= NOW() - INTERVAL '24 hours' AND success = false",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 5 },
        { "color": "red", "value": 20 }
      ] } } }
    },
    {
      "id": 7,
      "title": "Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT $__timeGroup(created_at, '5m', 0) AS time, COUNT(*) FILTER (WHERE success = true) AS \"Success\", COUNT(*) FILTER (WHERE success = false) AS \"Failed\" FROM llm_usage_logs WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT $__timeGroup(created_at, '5m', 0) AS time, ROUND(SUM(estimated_cost_usd)::numeric, 4) AS \"Cost USD\" FROM llm_usage_logs WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "bars", "fillOpacity": 60 } } }
    },
    {
      "id": 9,
      "title": "Latency Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT $__timeGroup(created_at, '5m') AS time, percentile_cont(0.50) WITHIN GROUP (ORDER BY latency_ms) AS \"p50\", percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS \"p95\", percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS \"p99\" FROM llm_usage_logs WHERE $__timeFilter(created_at) AND success = true GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 10,
      "title": "Usage by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT model AS \"Model\", COUNT(*) AS \"Requests\" FROM llm_usage_logs WHERE $__timeFilter(created_at) GROUP BY model ORDER BY 2 DESC",
        "format": "table"
      }]
    },
    {
      "id": 11,
      "title": "Token Usage by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT model AS \"Model\", SUM(total_tokens) AS \"Tokens\" FROM llm_usage_logs WHERE $__timeFilter(created_at) GROUP BY model ORDER BY 2 DESC",
        "format": "table"
      }]
    },
    {
      "id": 12,
      "title": "Error Breakdown",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT error_message AS \"Error\", COUNT(*) AS \"Count\", MAX(created_at) AS \"Last Seen\" FROM llm_usage_logs WHERE $__timeFilter(created_at) AND success = false AND error_message IS NOT NULL GROUP BY error_message ORDER BY 2 DESC LIMIT 20",
        "format": "table"
      }]
    },
    {
      "id": 13,
      "title": "Top Labels by Cost",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT label AS \"Label\", COUNT(*) AS \"Calls\", SUM(total_tokens) AS \"Tokens\", ROUND(SUM(estimated_cost_usd)::numeric, 4) AS \"Cost USD\", ROUND(AVG(latency_ms)) AS \"Avg ms\" FROM llm_usage_logs WHERE $__timeFilter(created_at) GROUP BY label ORDER BY 4 DESC LIMIT 15",
        "format": "table"
      }]
    },
    {
      "id": 14,
      "title": "LLM Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{container=~\".*app.*\"} |~ \"LLM_(TIER_FAILED|ALL_FAILED|TIER_NON_RETRYABLE)\"",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ],
  "schemaVersion": 39
}
